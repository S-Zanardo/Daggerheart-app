                  { "label": "+2 al Tiro", "effect": "add_result_modifier_2" },
                  { "label": "Raddoppia un Dado", "effect": "double_selected_damage_die" },
                  { "label": "Bersaglio Extra", "effect": "apply_hit_second_target" }
